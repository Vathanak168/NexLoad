# NexLoad Cloud Hosting Environment Variables
# Rename this file to .env or set these in your Cloud Hosting dashboard (Render, Railway, VPS)

HOST=0.0.0.0
PORT=5000
SECRET_KEY=NexLoad-Secret-2026-ChangeThis-To-Something-Unique

# Telegram Bot Integration (Get token from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Telegram Admin User IDs (comma separated) for /genkey and /stats commands
TELEGRAM_ADMIN_IDS=123456789

# Google OAuth 2.0 Client ID for Sign-in with Google & Automatic Single Sign-On (SSO)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
